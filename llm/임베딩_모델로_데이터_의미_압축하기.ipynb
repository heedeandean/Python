        "import faiss\n",
        "\n",
        "index = faiss.IndexFlatIP(embeddings.shape[1]) # KNN(K-Nearest Neighbor) 알고리즘 활용한 검색 인덱스 생성.\n",
        "index.add(embeddings) # 인덱스에 임베딩 저장."
      ],
      "metadata": {
        "id": "3wRDz7fmdrZS"
      },
      "execution_count": 10,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 의미 검색 장점: 키워드가 동일하지 않아도 의미가 유사하면 찾을 수 있다.\n",
        "query = \"이번 연도에는 언제 비가 많이 올까?\"\n",
        "query_embedding = sentence_model.encode([query]) # 문장 임베딩 변환.\n",
        "distances, indices = index.search(query_embedding, 3) # 검색\n",
        "\n",
        "for idx in indices[0]:\n",
        "    idx = int(idx)\n",
        "    print(klue_mrc_dataset['context'][idx][:50])"
